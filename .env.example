# FinAssistBH — Konfiguracija okoline
# -------------------------------------------------------
# UPUTE:
#   1. Kopiraj ovaj fajl: cp .env.example .env
#   2. Zamijeni vrijednosti ispod sa stvarnim podacima
#   3. .env fajl NIKAD ne commitaj na GitHub!
# -------------------------------------------------------

# Google Gemini API ključ
# Dobij na: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# JWT tajni ključ (za auth tokene)
# Generiši: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your_jwt_secret_here

# SQLite putanja (default: users.db u root projekta)
DB_PATH=users.db

# Supabase (login/register sistem)
# Dobij na: https://supabase.com/dashboard → Settings → API
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_key_here

# Stripe (plaćanje pretplata)
# Dobij na: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# Admin panel lozinka (za /admin stranicu)
# Promijeni ovo u nešto sigurno!
ADMIN_PASSWORD=promijeni_ovo_odmah
