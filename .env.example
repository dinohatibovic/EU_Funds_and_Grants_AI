# FinAssistBH — Environment configuration
# -------------------------------------------------------
# SETUP:
#   1. Copy this file:  cp .env.example .env
#   2. Replace the values below with real credentials
#   3. NEVER commit the .env file to GitHub!
# -------------------------------------------------------

# Google Gemini API key (required)
# Get one at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini generation model (optional, default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# JWT secret key for auth tokens (required in production)
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your_jwt_secret_here

# PostgreSQL / Supabase connection string (optional — SQLite fallback if unset)
# Supabase: Dashboard → Settings → Database → Connection string (URI)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# SQLite path (used only when DATABASE_URL is not set; default: users.db)
DB_PATH=users.db

# ChromaDB storage path (optional, default: vector_db/chroma_db_data)
# CHROMA_DB_PATH=vector_db/chroma_db_data

# Rate limiting (optional, defaults: 30 requests / 60 seconds per IP)
# RATE_LIMIT_REQUESTS=30
# RATE_LIMIT_WINDOW=60

# Stripe (subscription payments)
# Get keys at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here
